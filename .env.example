# ── Macro Trader Bot — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Finnhub (free tier — finnhub.io)
FINNHUB_API_KEY=

# FRED (free — fred.stlouisfed.org)
FRED_API_KEY=

# Alpaca paper trading (alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
PAPER_TRADING=true

# OANDA forex (practice account — oanda.com)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# NEWS_POLL_INTERVAL_SECONDS=300
# POSITION_MONITOR_INTERVAL_SECONDS=120
# NEWS_FETCH_TIMEOUT_SECONDS=10

# Signal thresholds
# SIGNAL_CONVICTION_THRESHOLD=0.4
# DEDUP_SIMILARITY_THRESHOLD=0.5
# DEDUP_WINDOW_HOURS=4

# Risk limits
# MAX_HOLD_HOURS=4
# MAX_TRADES_PER_DAY=10
# MAX_DAILY_LOSS_PCT=0.05
# MAX_POSITION_PCT=0.05
# STOP_LOSS_PCT=0.02

# Macro context thresholds
# FEDFUNDS_HIGH=4.0
# FEDFUNDS_LOW=2.0
# UNRATE_HIGH=5.5
# UNRATE_LOW=4.0
# DGS10_HIGH=4.0
# MACRO_REFRESH_CYCLES=12

# Database path (override if needed)
# DB_PATH=data/trading.db
